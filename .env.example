# .env.example — 변수 이름만 포함 (값 없음). 실제 값은 .env에 채운다.
# .env는 git commit 금지 (.gitignore로 차단).
# 관련 룰: .claude/rules/process.md P-3, .claude/rules/engineering.md E-4
#
# 비-시크릿 상수(robot_model, whisper_model_size, operator_id 등)는
# config/runtime.yaml로 분리. 여기는 시크릿 + 환경별로 다른 값만.

# === Cloud / API tokens (시크릿) ===
HUGGINGFACE_TOKEN=
LAMBDA_LABS_API_KEY=
VAST_AI_API_KEY=

# === VLA (Track C) — 환경별 경로 ===
VLA_MODEL_URL=
VLA_CHECKPOINT_PATH=

# === DB (미결 #3 결정 후 사용) ===
# SQLite 사용 시 경로만 필요:
DB_PATH=
# PostgreSQL 사용 시:
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# === PLC (미결 #2 결정 후 사용) — 네트워크 환경별 ===
PLC_HOST=
PLC_PORT=

# === Doosan 로봇 — 네트워크 환경별 ===
DOOSAN_ROBOT_IP=

# === RealSense — 머신별 시리얼 ===
REALSENSE_SERIAL=
