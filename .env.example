# .env.example — 변수 이름만 포함 (값 없음). 실제 값은 .env에 채운다.
# .env는 git commit 금지 (.gitignore로 차단).
# 관련 룰: .claude/rules/process.md P-3, .claude/rules/engineering.md E-4
#
# 비-시크릿 상수(robot_model, whisper_model_size, operator_id 등)는
# config/runtime.yaml로 분리. 여기는 시크릿 + 환경별로 다른 값만.

# === ROS2 미들웨어 격리 (Track A/B) ===
# Doosan 컨트롤러는 TCP(LAN)로 별도 통신하므로 DDS 설정과 무관.
# 같은 LAN의 다른 ROS2 프로젝트와의 토픽 충돌 방지용.
# 권장값: 팀별 유일 정수 (0–101). 본 프로젝트 권장 42.
ROS_DOMAIN_ID=42
# CycloneDDS 사용 (Humble 기본은 FastDDS — 명시적 지정 권장)
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
# HP ProBook이 같은 LAN에서 rqt 모니터링하므로 0으로 둔다. 1로 설정 시 루프백 전용.
ROS_LOCALHOST_ONLY=0

# === Cloud / API tokens (시크릿) ===
HUGGINGFACE_TOKEN=
LAMBDA_LABS_API_KEY=
VAST_AI_API_KEY=
# Roboflow 데이터셋 업로드·다운로드 (scripts/dataset/*, 코랩 학습 노트북)
ROBOFLOW_API_KEY=

# === VLA (Track C) — 환경별 경로 ===
VLA_MODEL_URL=
VLA_CHECKPOINT_PATH=

# === DB (미결 #3 결정 후 사용) ===
# SQLite 사용 시 경로만 필요:
DB_PATH=
# PostgreSQL 사용 시:
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# === PLC (미결 #2 결정 후 사용) — 네트워크 환경별 ===
PLC_HOST=
PLC_PORT=

# === Doosan 로봇 — 네트워크 환경별 ===
DOOSAN_ROBOT_IP=

# === RealSense — 머신별 시리얼 ===
REALSENSE_SERIAL=
