---
# 카메라–로봇 Hand-Eye 캘리브레이션 결과
#
# 구성: eye-to-hand, 탑뷰 고정 마운트
#       D455f가 작업공간 위 고정 위치에서 아래를 향해 장착
# 변환: camera_color_optical_frame → base_link
# 단위: m (translation), quaternion [x, y, z, w] (rotation) — E-1
# 갱신 조건: docs/hardware.md §5 참조
# 절차: scripts/calibrate_hand_eye.sh

schema_version: 1

# ⚠️ Phase 1 캘리브레이션 완료 후 실측값으로 교체 — 현재 미확정
transformation:
  rotation:
    x: 0.0    # TBD
    y: 0.0    # TBD
    z: 0.0    # TBD
    w: 1.0    # TBD
  translation:
    x: 0.0    # TBD [m], base_link 기준
    y: 0.0    # TBD [m]
    z: 0.0    # TBD [m]

metadata:
  calibration_date: null          # 캘리브레이션 완료 후 기입 (예: "2026-06-01")
  sample_count: null              # 권장 25개 이상
  reprojection_error_px: null     # 합격 기준 < 1.0 px
  position_error_mm: null         # 합격 기준 < 5 mm (G1 → 2 게이트)
  orientation_error_deg: null     # 합격 기준 < 2°
  operator: null
  tool: "easy_handeye2 + CharUco 8x6 (0.04m/0.03m)"
  frames:
    from: "camera_color_optical_frame"
    to: "base_link"
