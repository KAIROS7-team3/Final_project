# 로봇 시리얼 장치 — 고정 디바이스 노드
# VID/PID는 Phase 1 bring-up 시 udevadm info 로 확인 후 기입 (담당: B, A)
# 설치: scripts/udev/install_udev_rules.sh

# Doosan e0509 컨트롤러 (TCP/IP — udev 불필요, Ethernet 직결)
# 해당 없음

# ROBOTIS RH-P12-RN 그리퍼 (USB→RS-485, Dynamixel Protocol 2.0) — 담당: B
SUBSYSTEM=="tty", ATTRS{idVendor}=="XXXX", ATTRS{idProduct}=="XXXX", SYMLINK+="gripper"

# Logitech C270 HD WEBCAM (그리퍼 캠, /dev/c270 고정 심링크)
# video4linux 서브시스템 + capture 기능 노드만 선택 (metadata 노드 제외)
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="046d", ATTRS{idProduct}=="0825", ATTR{index}=="0", SYMLINK+="c270"

# PLC XBC-DR14E (RS-485 Modbus RTU, USB-Serial CH340) — 담당: A
SUBSYSTEM=="tty", ATTRS{idVendor}=="1a86", ATTRS{idProduct}=="7523", GROUP="dialout", MODE="0660", SYMLINK+="plc"
